# Local-first chat provider chain.
# The app tries providers in this order:
# 1. Ollama on your laptop
# 2. Gemini, if GEMINI_API_KEY is set
# 3. OpenRouter, if OPENROUTER_API_KEY is set
# 4. Legacy OpenAI/OpenAI-compatible config, if OPENAI_API_KEY is set
# If all fail, the agents use the existing deterministic demo fallback.

# Ollama / local Qwen
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
# Change this to the exact tag shown by `ollama list` on your laptop.
OLLAMA_MODEL=qwen2.5-coder:3b

# Ollama / local embeddings for private RAG retrieval
OLLAMA_EMBEDDINGS_ENABLED=true
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# Shared generation cap for all chat providers.
LLM_MAX_TOKENS=2000

# Backup 1: Gemini OpenAI-compatible endpoint
# GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MAIN_MODEL=gemini-2.0-flash
GEMINI_EVALUATOR_MODEL=gemini-2.0-flash

# Backup 2: OpenRouter free-tier model, or replace with any OpenAI-compatible provider.
# OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAIN_MODEL=openrouter/free
OPENROUTER_EVALUATOR_MODEL=openrouter/free

# Optional legacy provider. This remains useful for OpenAI, Groq, Gemini via
# OPENAI_BASE_URL, or any other OpenAI-compatible service.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
MAIN_LLM_MODEL=gpt-4o-mini
EVALUATOR_LLM_MODEL=gpt-4o-mini
# Used only if OPENAI_API_KEY is set or Ollama embeddings fail.
EMBEDDING_MODEL=text-embedding-3-small

# Optional Neo4j Aura persistence.
# When set, POST /api/analyse automatically writes the case, analysis,
# deductions, uploaded document metadata, and retrieved source links to Neo4j.
NEO4J_URI=neo4j+s://<dbid>.databases.neo4j.io
NEO4J_QUERY_API_URL=https://<dbid>.databases.neo4j.io/db/<database>/query/v2
NEO4J_USERNAME=<dbid>
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
